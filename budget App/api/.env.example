# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/budgetlens

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://localhost:5672

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=2592000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed web origins
CORS_ORIGINS=http://localhost:3001

# ── AWS (receipt image storage + OCR) ────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me
S3_BUCKET=budgetlens-receipts

# ── Azure OpenAI (NLP categorisation) ────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=replace_me
AZURE_OPENAI_DEPLOYMENT=gpt-4o
